{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "../../dist/out-tsc",
		"module": "commonjs",
		"moduleResolution": "node10",
		"types": ["jest", "node"],
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"],
			"@test/*": ["test/*"]
		}
	},
	"include": ["jest.config.ts", "src/**/*.d.ts", "test/**/*.spec.ts", "test/**/*.test.ts"]
}
